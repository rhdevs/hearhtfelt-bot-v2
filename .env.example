# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
ADMIN_CHANNEL_ID=your_admin_channel_id_here

# MongoDB Configuration (optional - bot will run in memory-only mode if not provided)
# Example: mongodb://localhost:27017/heartfelt_bot
# Example: mongodb+srv://username:password@cluster.mongodb.net/heartfelt_bot
MONGODB_URI=mongodb://localhost:27017/heartfelt_bot