# Test Environment Configuration for Heartfelt Bot
# 
# INSTRUCTIONS:
# 1. Replace <YOUR_TEST_BOT_TOKEN> with your test bot token from @BotFather
# 2. Replace <YOUR_TEST_CHANNEL_ID> with your test channel ID (get from @userinfobot)
# 3. Test database will be created automatically at <YOUR_TEST_DATABASE_NAME>

# Test Bot Token (replace with your test bot token)
BOT_TOKEN=your_bot_token_here

# Test Admin Channel ID (replace with your test channel ID)
ADMIN_CHANNEL_ID=your_admin_channel_id_here

# Test MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/<YOUR_TEST_DATABASE_NAME>